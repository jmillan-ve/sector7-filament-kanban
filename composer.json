{
    "name": "sector7/filament-kanban",
    "description": "Add kanban boards to your Filament v5 pages with Sortable.js drag and drop",
    "keywords": [
        "sector7",
        "laravel",
        "filament",
        "filament-kanban",
        "kanban",
        "kanban-board"
    ],
    "homepage": "https://github.com/jmillan-ve/sector7-filament-kanban",
    "support": {
        "issues": "https://github.com/jmillan-ve/sector7-filament-kanban/issues",
        "source": "https://github.com/jmillan-ve/sector7-filament-kanban"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Sector7",
            "email": "sector7@example.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^7.9|^8.0",
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0",
        "spatie/eloquent-sortable": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Sector7\\FilamentKanban\\": "src/",
            "Sector7\\FilamentKanban\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sector7\\FilamentKanban\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        },
        "audit": {
            "ignore": ["PKSA-ndkp-2znf-9m7c", "PKSA-5bdf-2x61-v43c"]
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sector7\\FilamentKanban\\FilamentKanbanServiceProvider"
            ],
            "aliases": {
                "FilamentKanban": "Sector7\\FilamentKanban\\Facades\\FilamentKanban"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
